# ============================================
# OPENAI API
# ============================================
OPENAI_API_KEY=tu_api_key_de_openai_aqui
OPENAI_MODEL=gpt-4o
OPENAI_PROMPT_ID=pmpt_tu_prompt_id_aqui

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3050
NODE_ENV=development

# ============================================
# JWT Y SEGURIDAD
# ============================================
JWT_SECRET=clasificador-arancelario-secret-key-2025-cambia-esto-en-produccion

# ============================================
# MONGODB
# ============================================
MONGODB_URI=mongodb://localhost:27017/clasificador_arancelario

# ============================================
# CONFIGURACIÓN DE EMAIL (Servicio Transaccional)
# ============================================
# RECOMENDADO: Usar servicio transaccional para múltiples empresas
# SendGrid (GRATIS: 100 emails/día) - Recomendado
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=apikey
EMAIL_PASSWORD=tu_sendgrid_api_key_aqui
EMAIL_FROM=noreply@tudominio.com

# AWS SES (Muy escalable)
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=tu_aws_smtp_username
# EMAIL_PASSWORD=tu_aws_smtp_password
# EMAIL_FROM=noreply@tudominio.com

# Mailgun (10,000 emails gratis/mes)
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=tu_mailgun_smtp_user
# EMAIL_PASSWORD=tu_mailgun_smtp_password
# EMAIL_FROM=noreply@tudominio.com

# OPCIÓN 2: Gmail (NO recomendado para producción, solo desarrollo)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=tu_email@gmail.com
# EMAIL_PASSWORD=tu_app_password
# EMAIL_FROM=tu_email@gmail.com

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
FRONTEND_URL=http://localhost:3050
APP_NAME=Clasificador Arancelario RD

# ============================================
# CONFIGURACIÓN DE ARCHIVOS
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ============================================
# CONFIGURACIÓN DE CORS
# ============================================
ALLOWED_ORIGINS=http://localhost:3050,http://127.0.0.1:3050,http://localhost:5500

# ============================================
# INSTRUCCIONES PARA CONFIGURAR EMAIL
# ============================================
# 
# ===========================================
# GUÍA DE CONFIGURACIÓN DE EMAIL
# ===========================================
#
# SENDGRID (Recomendado - Gratis 100 emails/día):
# 1. Crea cuenta en https://sendgrid.com
# 2. Ve a Settings > API Keys
# 3. Crea un API Key con permisos de "Mail Send"
# 4. Copia el API Key en EMAIL_PASSWORD
# 5. Verifica tu dominio o usa dominio compartido
# 6. EMAIL_USER siempre es "apikey"
#
# AWS SES (Escalable - $0.10 por 1000 emails):
# 1. Configura AWS SES en tu cuenta AWS
# 2. Genera credenciales SMTP
# 3. Verifica tu dominio
# 4. Copia username/password SMTP
#
# MAILGUN (10,000 emails gratis/mes):
# 1. Crea cuenta en https://mailgun.com
# 2. Ve a Sending > Domain settings
# 3. Obtén credenciales SMTP
# 4. Verifica tu dominio
#
# NOTA IMPORTANTE:
# - Las empresas pueden tener su propio SMTP (se guarda en la colección "empresas")
# - Campos opcionales en empresas: smtp_host, smtp_port, smtp_user, smtp_password, email_from
# - Si la empresa no tiene SMTP, se usa el servicio centralizado configurado aquí